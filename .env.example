# =============================================================
# Max's Top Picks - Local Development Environment Variables
# =============================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Required ---

# PostgreSQL connection string
# If using Docker Compose: postgresql://postgres:postgres@localhost:5432/maxtoppicks
# If using your own PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maxtoppicks

# --- Admin Panel ---

# Password for the admin panel (default: "max123")
ADMIN_PASSWORD=max123

# --- Local Development ---

# Set to "true" to use local filesystem for image storage instead of cloud Object Storage
# Images will be saved to ./local-uploads/ directory
LOCAL_STORAGE=true

# Port for the dev server (default: 5000)
PORT=5000

# --- Optional: Amazon Product Import ---

# Amazon Product Advertising API credentials (official method)
# Get these from: Associates Central → Tools → Product Advertising API
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=maxtoppicks-20

# ScraperAPI key for web scraping fallback (free tier: 1000 req/month at scraperapi.com)
# SCRAPER_API_KEY=

# --- Optional: AI Text Generation ---

# OpenAI API key for AI-generated product descriptions
# OPENAI_API_KEY=

# --- Optional: Replit Auth (only works on Replit) ---

# SESSION_SECRET=your-random-session-secret
# REPL_ID=
# ISSUER_URL=https://replit.com/oidc
